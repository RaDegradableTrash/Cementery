## 3. URP 后处理管线搭建指南（自写 Shader 架构）

为了渲染远处的无边云海，最经济的做法是将体积云写成一个 **后处理（Post-Processing Render Feature）**，或者挂在天空盒上的 **Raymarched Skybox**。

### 核心 Shader 伪代码与算法架构：

```hlsl
// 基础写实光照模型：Beer + Powder 效应
float LightEnergy(float densityToSun, float absorption)
{
    // 比尔定律：模拟光线穿过云层的衰减（核心阴影）
    float beer = exp(-densityToSun * absorption); 
    
    // 粉末效应：模拟云层边缘由于多重散射产生的亮边，同时让暗部更厚重
    float powder = 1.0 - exp(-densityToSun * 2.0); 
    
    return beer * powder;
}

// 主渲染循环
float4 Frag(Varyings input) : SV_Target
{
    // 1. 根据屏幕坐标重建视线方向 (Ray Direction)
    float3 rayOrigin = _WorldSpaceCameraPos;
    float3 rayDir = GetAbsoluteRayDirection(input.uv);
    
    // 2. 射线与高空云层包围盒（例如海拔 2000m 到 4000m 的平面）求交点
    float tNear, tFar;
    if (!IntersectCloudBox(rayOrigin, rayDir, tNear, tFar)) return float4(0,0,0,0); // 没射中云层，直接返回透明

    float4 finalColor = float4(0,0,0,0);
    float stepSize = (tFar - tNear) / 16.0; // 严格控制在 16 次步进
    
    // 3. Raymarching 核心循环
    for(int i = 0; i < 16; i++)
    {
        float3 currentPos = rayOrigin + rayDir * (tNear + i * stepSize);
        
        // 动态混叠采样 3D 噪声
        float density = SampleCloudDensity(currentPos); 
        
        if (density > 0.01)
        {
            // 核心偷懒阴影：只朝太阳方向偏移一步采样密度
            float densityToSun = SampleCloudDensity(currentPos + _MainLightPosition.xyz * 30.0);
            
            // 计算写实光照
            float light = LightEnergy(densityToSun, _Absorption) * _MainLightColor.rgb;
            
            // 融入高度阴影渐变 (电影感暗部)
            float heightFactor = (currentPos.y - _CloudMinHeight) / (_CloudMaxHeight - _CloudMinHeight);
            float3 cloudColor = lerp(_ShadowColor, _MaxLightColor, heightFactor * light);
            
            // 传统的阿尔法混合 (Front-to-Back Alpha Blending)
            float alpha = density * _CloudDensityScale;
            finalColor.rgb += (1.0 - finalColor.a) * cloudColor * alpha;
            finalColor.a += (1.0 - finalColor.a) * alpha;
            
            if (finalColor.a >= 0.95) break; // 已经不透明了，提前结束（Early Exit）
        }
    }
    return finalColor;
}

```

